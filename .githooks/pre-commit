#!/usr/bin/env bash
set -euo pipefail

echo "=== Pre-commit: Auto-fix fmt & clippy ==="

# Prefer the justfile recipe so checks stay defined in one place;
# fall back to the raw commands if `just` is not installed.
if command -v just >/dev/null 2>&1; then
    just pre-commit
else
    echo "(just not found — running cargo directly)"
    cargo fmt --all
    cargo clippy --all-targets -- -D warnings
fi
echo "OK"

echo "--- Stage fixed files ---"
git diff --cached --name-only --diff-filter=ACMR | xargs -r git add
echo "OK"

echo "=== All checks passed ==="
