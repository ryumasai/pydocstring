{
    "name": "pydocstring",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
                "ms-python.python",
                "charliermarsh.ruff"
            ],
            "settings": {
                "editor.formatOnSave": true,
                "rust-analyzer.checkOnSave.command": "clippy",
                "python.defaultInterpreterPath": "${workspaceFolder}/bindings/python/.venv/bin/python"
            }
        }
    },
    "postCreateCommand": "cd bindings/python && uv sync && uv run maturin develop --uv"
}
