    }
    NEWLINE: "\n"@5363..5364
    ENTRY@5364..5423 {
      TYPE: "If `data` is array-like and `return_info=False` was passed,"@5364..5423
    }
    NEWLINE: "\n"@5423..5424
    ENTRY@5424..5484 {
      TYPE: "this function returns the PCA representation of `data` as an"@5424..5484
    }
    NEWLINE: "\n"@5484..5485
    ENTRY@5485..5527 {
      TYPE: "array of the same type as the input array."@5485..5527
    }
    NEWLINE: "\n"@5527..5528
    BLANK_LINE: "\n"@5528..5529
    ENTRY@5529..5608 {
      TYPE: "Otherwise, it returns `None` if `copy=False`, else an updated `AnnData` object."@5529..5608
    }
    NEWLINE: "\n"@5608..5609
