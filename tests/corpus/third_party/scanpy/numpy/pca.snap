      NEWLINE: "\n"@4757..4758
      WHITESPACE: "    "@4758..4762
      DESCRIPTION@4762..5229 {
        TEXT_LINE: "If not specified, the embedding is stored as"@4762..4806
        NEWLINE: "\n"@4806..4807
        WHITESPACE: "    "@4807..4811
        TEXT_LINE: ":attr:`~anndata.AnnData.obsm`\\ `['X_pca']`, the loadings as"@4811..4870
        NEWLINE: "\n"@4870..4871
        WHITESPACE: "    "@4871..4875
        TEXT_LINE: ":attr:`~anndata.AnnData.varm`\\ `['PCs']`, and the the parameters in"@4875..4942
        NEWLINE: "\n"@4942..4943
        WHITESPACE: "    "@4943..4947
        TEXT_LINE: ":attr:`~anndata.AnnData.uns`\\ `['pca']`."@4947..4987
        NEWLINE: "\n"@4987..4988
        WHITESPACE: "    "@4988..4992
        TEXT_LINE: "If specified, the embedding is stored as"@4992..5032
        NEWLINE: "\n"@5032..5033
        WHITESPACE: "    "@5033..5037
        TEXT_LINE: ":attr:`~anndata.AnnData.obsm`\\ ``[key_added]``, the loadings as"@5037..5100
        NEWLINE: "\n"@5100..5101
        WHITESPACE: "    "@5101..5105
        TEXT_LINE: ":attr:`~anndata.AnnData.varm`\\ ``[key_added]``, and the the parameters in"@5105..5178
        NEWLINE: "\n"@5178..5179
        WHITESPACE: "    "@5179..5183
        TEXT_LINE: ":attr:`~anndata.AnnData.uns`\\ ``[key_added]``."@5183..5229
      }
    }
    NEWLINE: "\n"@5229..5230
    ENTRY@5230..5346 {
      NAME: "copy"@5230..5234
      NEWLINE: "\n"@5234..5235
      WHITESPACE: "    "@5235..5239
      DESCRIPTION@5239..5346 {
        TEXT_LINE: "If an :class:`~anndata.AnnData` is passed, determines whether a copy"@5239..5307
        NEWLINE: "\n"@5307..5308
        WHITESPACE: "    "@5308..5312
        TEXT_LINE: "is returned. Is ignored otherwise."@5312..5346
      }
    }
  }
