  NEWLINE: "\n"@5779..5780
  BLANK_LINE: "\n"@5780..5781
  SECTION@5781..7904 {
    SECTION_HEADER@5781..5798 {
      NAME: "Examples"@5781..5789
      NEWLINE: "\n"@5789..5790
      UNDERLINE: "--------"@5790..5798
    }
    NEWLINE: "\n"@5798..5799
    DESCRIPTION@5799..7904 {
      TEXT_LINE: "In this example the cubic spline is used to interpolate a sampled sinusoid."@5799..5874
      NEWLINE: "\n"@5874..5875
      TEXT_LINE: "You can see that the spline continuity property holds for the first and"@5875..5946
      NEWLINE: "\n"@5946..5947
      TEXT_LINE: "second derivatives and violates only for the third derivative."@5947..6009
      NEWLINE: "\n"@6009..6010
      BLANK_LINE: "\n"@6010..6011
      TEXT_LINE: ">>> import numpy as np"@6011..6033
      NEWLINE: "\n"@6033..6034
      TEXT_LINE: ">>> from scipy.interpolate import CubicSpline"@6034..6079
      NEWLINE: "\n"@6079..6080
      TEXT_LINE: ">>> import matplotlib.pyplot as plt"@6080..6115
      NEWLINE: "\n"@6115..6116
      TEXT_LINE: ">>> x = np.arange(10)"@6116..6137
      NEWLINE: "\n"@6137..6138
      TEXT_LINE: ">>> y = np.sin(x)"@6138..6155
      NEWLINE: "\n"@6155..6156
      TEXT_LINE: ">>> cs = CubicSpline(x, y)"@6156..6182
      NEWLINE: "\n"@6182..6183
      TEXT_LINE: ">>> xs = np.arange(-0.5, 9.6, 0.1)"@6183..6217
      NEWLINE: "\n"@6217..6218
      TEXT_LINE: ">>> fig, ax = plt.subplots(figsize=(6.5, 4))"@6218..6262
      NEWLINE: "\n"@6262..6263
      TEXT_LINE: ">>> ax.plot(x, y, 'o', label='data')"@6263..6299
      NEWLINE: "\n"@6299..6300
      TEXT_LINE: ">>> ax.plot(xs, np.sin(xs), label='true')"@6300..6341
      NEWLINE: "\n"@6341..6342
