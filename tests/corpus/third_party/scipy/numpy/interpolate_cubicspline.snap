=== CST ===
DOCUMENT@0..7904 {
  SUMMARY@0..55 {
    TEXT_LINE: "Piecewise cubic interpolator to fit values (C2 smooth)."@0..55
  }
  NEWLINE: "\n"@55..56
  BLANK_LINE: "\n"@56..57
  EXTENDED_SUMMARY@57..246 {
    TEXT_LINE: "Interpolate data with a piecewise cubic polynomial which is twice"@57..122
    NEWLINE: "\n"@122..123
    TEXT_LINE: "continuously differentiable [1]_. The result is represented as a `PPoly`"@123..195
    NEWLINE: "\n"@195..196
    TEXT_LINE: "instance with breakpoints matching the given data."@196..246
  }
  NEWLINE: "\n"@246..247
  BLANK_LINE: "\n"@247..248
  SECTION@248..3004 {
    SECTION_HEADER@248..269 {
      NAME: "Parameters"@248..258
      NEWLINE: "\n"@258..259
      UNDERLINE: "----------"@259..269
    }
    NEWLINE: "\n"@269..270
    ENTRY@270..423 {
      NAME: "x"@270..271
      WHITESPACE: " "@271..272
      COLON: ":"@272..273
      WHITESPACE: " "@273..274
      TYPE: "array_like, shape (n,)"@274..296
      NEWLINE: "\n"@296..297
      WHITESPACE: "    "@297..301
      DESCRIPTION@301..423 {
        TEXT_LINE: "1-D array containing values of the independent variable."@301..357
        NEWLINE: "\n"@357..358
        WHITESPACE: "    "@358..362
        TEXT_LINE: "Values must be real, finite and in strictly increasing order."@362..423
      }
    }
    NEWLINE: "\n"@423..424
    ENTRY@424..642 {
      NAME: "y"@424..425
      WHITESPACE: " "@425..426
      COLON: ":"@426..427
      WHITESPACE: " "@427..428
      TYPE: "array_like"@428..438
      NEWLINE: "\n"@438..439
      WHITESPACE: "    "@439..443
      DESCRIPTION@443..642 {
        TEXT_LINE: "Array containing values of the dependent variable. It can have"@443..505
        NEWLINE: "\n"@505..506
        WHITESPACE: "    "@506..510
        TEXT_LINE: "arbitrary number of dimensions, but the length along ``axis``"@510..571
        NEWLINE: "\n"@571..572
        WHITESPACE: "    "@572..576
        TEXT_LINE: "(see below) must match the length of ``x``. Values must be finite."@576..642
      }
    }
    NEWLINE: "\n"@642..643
    ENTRY@643..821 {
      NAME: "axis"@643..647
      WHITESPACE: " "@647..648
      COLON: ":"@648..649
      WHITESPACE: " "@649..650
      TYPE: "int"@650..653
      COMMA: ","@653..654
      WHITESPACE: " "@654..655
      OPTIONAL: "optional"@655..663
      NEWLINE: "\n"@663..664
      WHITESPACE: "    "@664..668
      DESCRIPTION@668..821 {
        TEXT_LINE: "Axis along which `y` is assumed to be varying. Meaning that for"@668..731
        NEWLINE: "\n"@731..732
        WHITESPACE: "    "@732..736
        TEXT_LINE: "``x[i]`` the corresponding values are ``np.take(y, i, axis=axis)``."@736..803
        NEWLINE: "\n"@803..804
        WHITESPACE: "    "@804..808
        TEXT_LINE: "Default is 0."@808..821
      }
    }
    NEWLINE: "\n"@821..822
    ENTRY@822..2614 {
      NAME: "bc_type"@822..829
      WHITESPACE: " "@829..830
      COLON: ":"@830..831
      WHITESPACE: " "@831..832
      TYPE: "str or 2-tuple"@832..846
      COMMA: ","@846..847
      WHITESPACE: " "@847..848
      OPTIONAL: "optional"@848..856
      NEWLINE: "\n"@856..857
      WHITESPACE: "    "@857..861
      DESCRIPTION@861..2614 {
        TEXT_LINE: "Boundary condition type. Two additional equations, given by the"@861..924
        NEWLINE: "\n"@924..925
        WHITESPACE: "    "@925..929
        TEXT_LINE: "boundary conditions, are required to determine all coefficients of"@929..995
        NEWLINE: "\n"@995..996
        WHITESPACE: "    "@996..1000
        TEXT_LINE: "polynomials on each segment [2]_."@1000..1033
        NEWLINE: "\n"@1033..1034
        BLANK_LINE: "    \n"@1034..1039
        WHITESPACE: "    "@1039..1043
        TEXT_LINE: "If `bc_type` is a string, then the specified condition will be applied"@1043..1113
        NEWLINE: "\n"@1113..1114
        WHITESPACE: "    "@1114..1118
        TEXT_LINE: "at both ends of a spline. Available conditions are:"@1118..1169
        NEWLINE: "\n"@1169..1170
        BLANK_LINE: "    \n"@1170..1175
        WHITESPACE: "    "@1175..1179
        TEXT_LINE: "* 'not-a-knot' (default): The first and second segment at a curve end"@1179..1248
        NEWLINE: "\n"@1248..1249
        WHITESPACE: "      "@1249..1255
        TEXT_LINE: "are the same polynomial. It is a good default when there is no"@1255..1317
        NEWLINE: "\n"@1317..1318
        WHITESPACE: "      "@1318..1324
        TEXT_LINE: "information on boundary conditions."@1324..1359
        NEWLINE: "\n"@1359..1360
        WHITESPACE: "    "@1360..1364
        TEXT_LINE: "* 'periodic': The interpolated functions is assumed to be periodic"@1364..1430
        NEWLINE: "\n"@1430..1431
        WHITESPACE: "      "@1431..1437
        TEXT_LINE: "of period ``x[-1] - x[0]``. The first and last value of `y` must be"@1437..1504
        NEWLINE: "\n"@1504..1505
        WHITESPACE: "      "@1505..1511
        TEXT_LINE: "identical: ``y[0] == y[-1]``. This boundary condition will result in"@1511..1579
        NEWLINE: "\n"@1579..1580
        WHITESPACE: "      "@1580..1586
        TEXT_LINE: "``y'[0] == y'[-1]`` and ``y''[0] == y''[-1]``."@1586..1632
        NEWLINE: "\n"@1632..1633
        WHITESPACE: "    "@1633..1637
        TEXT_LINE: "* 'clamped': The first derivative at curves ends are zero. Assuming"@1637..1704
        NEWLINE: "\n"@1704..1705
        WHITESPACE: "      "@1705..1711
        TEXT_LINE: "a 1D `y`, ``bc_type=((1, 0.0), (1, 0.0))`` is the same condition."@1711..1776
        NEWLINE: "\n"@1776..1777
        WHITESPACE: "    "@1777..1781
        TEXT_LINE: "* 'natural': The second derivative at curve ends are zero. Assuming"@1781..1848
        NEWLINE: "\n"@1848..1849
        WHITESPACE: "      "@1849..1855
        TEXT_LINE: "a 1D `y`, ``bc_type=((2, 0.0), (2, 0.0))`` is the same condition."@1855..1920
        NEWLINE: "\n"@1920..1921
        BLANK_LINE: "    \n"@1921..1926
        WHITESPACE: "    "@1926..1930
        TEXT_LINE: "If `bc_type` is a 2-tuple, the first and the second value will be"@1930..1995
        NEWLINE: "\n"@1995..1996
        WHITESPACE: "    "@1996..2000
        TEXT_LINE: "applied at the curve start and end respectively. The tuple values can"@2000..2069
        NEWLINE: "\n"@2069..2070
        WHITESPACE: "    "@2070..2074
        TEXT_LINE: "be one of the previously mentioned strings (except 'periodic') or a"@2074..2141
        NEWLINE: "\n"@2141..2142
        WHITESPACE: "    "@2142..2146
        TEXT_LINE: "tuple ``(order, deriv_values)`` allowing to specify arbitrary"@2146..2207
        NEWLINE: "\n"@2207..2208
        WHITESPACE: "    "@2208..2212
        TEXT_LINE: "derivatives at curve ends:"@2212..2238
        NEWLINE: "\n"@2238..2239
        BLANK_LINE: "    \n"@2239..2244
        WHITESPACE: "    "@2244..2248
        TEXT_LINE: "* `order`: the derivative order, 1 or 2."@2248..2288
        NEWLINE: "\n"@2288..2289
        WHITESPACE: "    "@2289..2293
        TEXT_LINE: "* `deriv_value`: array_like containing derivative values, shape must"@2293..2361
        NEWLINE: "\n"@2361..2362
        WHITESPACE: "      "@2362..2368
        TEXT_LINE: "be the same as `y`, excluding ``axis`` dimension. For example, if"@2368..2433
        NEWLINE: "\n"@2433..2434
        WHITESPACE: "      "@2434..2440
        TEXT_LINE: "`y` is 1-D, then `deriv_value` must be a scalar. If `y` is 3-D with"@2440..2507
        NEWLINE: "\n"@2507..2508
        WHITESPACE: "      "@2508..2514
        TEXT_LINE: "the shape (n0, n1, n2) and axis=2, then `deriv_value` must be 2-D"@2514..2579
        NEWLINE: "\n"@2579..2580
        WHITESPACE: "      "@2580..2586
        TEXT_LINE: "and have the shape (n0, n1)."@2586..2614
      }
    }
    NEWLINE: "\n"@2614..2615
    ENTRY@2615..3004 {
      NAME: "extrapolate"@2615..2626
      WHITESPACE: " "@2626..2627
      COLON: ":"@2627..2628
      WHITESPACE: " "@2628..2629
      TYPE: "{bool, 'periodic', None}"@2629..2653
      COMMA: ","@2653..2654
      WHITESPACE: " "@2654..2655
      OPTIONAL: "optional"@2655..2663
      NEWLINE: "\n"@2663..2664
      WHITESPACE: "    "@2664..2668
      DESCRIPTION@2668..3004 {
        TEXT_LINE: "If bool, determines whether to extrapolate to out-of-bounds points"@2668..2734
        NEWLINE: "\n"@2734..2735
        WHITESPACE: "    "@2735..2739
        TEXT_LINE: "based on first and last intervals, or to return NaNs. If 'periodic',"@2739..2807
        NEWLINE: "\n"@2807..2808
        WHITESPACE: "    "@2808..2812
        TEXT_LINE: "periodic extrapolation is used. If None (default), ``extrapolate`` is"@2812..2881
        NEWLINE: "\n"@2881..2882
        WHITESPACE: "    "@2882..2886
        TEXT_LINE: "set to 'periodic' for ``bc_type='periodic'`` and to True otherwise."@2886..2953
        NEWLINE: "\n"@2953..2954
        WHITESPACE: "    "@2954..2958
        TEXT_LINE: "See :ref:`tutorial-interpolate_out_of_bounds`."@2958..3004
      }
    }
  }
  NEWLINE: "\n"@3004..3005
  BLANK_LINE: "\n"@3005..3006
  SECTION@3006..3515 {
    SECTION_HEADER@3006..3027 {
      NAME: "Attributes"@3006..3016
      NEWLINE: "\n"@3016..3017
      UNDERLINE: "----------"@3017..3027
    }
    NEWLINE: "\n"@3027..3028
    ENTRY@3028..3120 {
      NAME: "x"@3028..3029
      WHITESPACE: " "@3029..3030
      COLON: ":"@3030..3031
      WHITESPACE: " "@3031..3032
      TYPE: "ndarray, shape (n,)"@3032..3051
      NEWLINE: "\n"@3051..3052
      WHITESPACE: "    "@3052..3056
      DESCRIPTION@3056..3120 {
        TEXT_LINE: "Breakpoints. The same ``x`` which was passed to the constructor."@3056..3120
      }
    }
    NEWLINE: "\n"@3120..3121
    ENTRY@3121..3425 {
      NAME: "c"@3121..3122
      WHITESPACE: " "@3122..3123
      COLON: ":"@3123..3124
      WHITESPACE: " "@3124..3125
      TYPE: "ndarray, shape (4, n-1, ...)"@3125..3153
      NEWLINE: "\n"@3153..3154
      WHITESPACE: "    "@3154..3158
      DESCRIPTION@3158..3425 {
        TEXT_LINE: "Coefficients of the polynomials on each segment. The trailing"@3158..3219
        NEWLINE: "\n"@3219..3220
        WHITESPACE: "    "@3220..3224
        TEXT_LINE: "dimensions match the dimensions of `y`, excluding ``axis``."@3224..3283
        NEWLINE: "\n"@3283..3284
        WHITESPACE: "    "@3284..3288
        TEXT_LINE: "For example, if `y` is 1-d, then ``c[k, i]`` is a coefficient for"@3288..3353
        NEWLINE: "\n"@3353..3354
        WHITESPACE: "    "@3354..3358
        TEXT_LINE: "``(x-x[i])**(3-k)`` on the segment between ``x[i]`` and ``x[i+1]``."@3358..3425
      }
    }
    NEWLINE: "\n"@3425..3426
    ENTRY@3426..3515 {
      NAME: "axis"@3426..3430
      WHITESPACE: " "@3430..3431
      COLON: ":"@3431..3432
      WHITESPACE: " "@3432..3433
      TYPE: "int"@3433..3436
      NEWLINE: "\n"@3436..3437
      WHITESPACE: "    "@3437..3441
      DESCRIPTION@3441..3515 {
        TEXT_LINE: "Interpolation axis. The same axis which was passed to the"@3441..3498
        NEWLINE: "\n"@3498..3499
        WHITESPACE: "    "@3499..3503
        TEXT_LINE: "constructor."@3503..3515
      }
    }
  }
  NEWLINE: "\n"@3515..3516
  BLANK_LINE: "\n"@3516..3517
