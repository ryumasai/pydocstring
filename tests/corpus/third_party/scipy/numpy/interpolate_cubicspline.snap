    ENTRY@3610..3664 {
      NAME: ":func:`Akima1DInterpolator`"@3610..3637
      NEWLINE: "\n"@3637..3638
      WHITESPACE: "    "@3638..3642
      DESCRIPTION@3642..3664 {
        TEXT_LINE: "Akima 1D interpolator."@3642..3664
      }
    }
    NEWLINE: "\n"@3664..3665
    ENTRY@3665..3734 {
      NAME: ":func:`PchipInterpolator`"@3665..3690
      NEWLINE: "\n"@3690..3691
      WHITESPACE: "    "@3691..3695
      DESCRIPTION@3695..3734 {
        TEXT_LINE: "PCHIP 1-D monotonic cubic interpolator."@3695..3734
      }
    }
    NEWLINE: "\n"@3734..3735
    ENTRY@3735..3815 {
      NAME: ":func:`PPoly`"@3735..3748
      NEWLINE: "\n"@3748..3749
      WHITESPACE: "    "@3749..3753
      DESCRIPTION@3753..3815 {
        TEXT_LINE: "Piecewise polynomial in terms of coefficients and breakpoints."@3753..3815
      }
    }
  }
  NEWLINE: "\n"@3815..3816
  BLANK_LINE: "\n"@3816..3817
  BLANK_LINE: "\n"@3817..3818
  SECTION@3818..5549 {
    SECTION_HEADER@3818..3829 {
      NAME: "Notes"@3818..3823
      NEWLINE: "\n"@3823..3824
      UNDERLINE: "-----"@3824..3829
    }
    NEWLINE: "\n"@3829..3830
    DESCRIPTION@3830..5549 {
      TEXT_LINE: "Parameters `bc_type` and ``extrapolate`` work independently, i.e. the"@3830..3899
      NEWLINE: "\n"@3899..3900
      TEXT_LINE: "former controls only construction of a spline, and the latter only"@3900..3966
      NEWLINE: "\n"@3966..3967
      TEXT_LINE: "evaluation."@3967..3978
      NEWLINE: "\n"@3978..3979
      BLANK_LINE: "\n"@3979..3980
      TEXT_LINE: "When a boundary condition is 'not-a-knot' and n = 2, it is replaced by"@3980..4050
      NEWLINE: "\n"@4050..4051
      TEXT_LINE: "a condition that the first derivative is equal to the linear interpolant"@4051..4123
      NEWLINE: "\n"@4123..4124
      TEXT_LINE: "slope. When both boundary conditions are 'not-a-knot' and n = 3, the"@4124..4192
      NEWLINE: "\n"@4192..4193
      TEXT_LINE: "solution is sought as a parabola passing through given points."@4193..4255
      NEWLINE: "\n"@4255..4256
      BLANK_LINE: "\n"@4256..4257
      TEXT_LINE: "When 'not-a-knot' boundary conditions is applied to both ends, the"@4257..4323
      NEWLINE: "\n"@4323..4324
      TEXT_LINE: "resulting spline will be the same as returned by `splrep` (with ``s=0``)"@4324..4396
      NEWLINE: "\n"@4396..4397
      TEXT_LINE: "and `InterpolatedUnivariateSpline`, but these two methods use a"@4397..4460
      NEWLINE: "\n"@4460..4461
      TEXT_LINE: "representation in B-spline basis."@4461..4494
      NEWLINE: "\n"@4494..4495
      BLANK_LINE: "\n"@4495..4496
      TEXT_LINE: ".. versionadded:: 0.18.0"@4496..4520
      NEWLINE: "\n"@4520..4521
      BLANK_LINE: "\n"@4521..4522
      TEXT_LINE: "**Array API Standard Support**"@4522..4552
      NEWLINE: "\n"@4552..4553
      BLANK_LINE: "\n"@4553..4554
      TEXT_LINE: "`CubicSpline` has experimental support for Python Array API Standard compatible"@4554..4633
      NEWLINE: "\n"@4633..4634
      TEXT_LINE: "backends in addition to NumPy. Please consider testing these features"@4634..4703
      NEWLINE: "\n"@4703..4704
      TEXT_LINE: "by setting an environment variable ``SCIPY_ARRAY_API=1`` and providing"@4704..4774
      NEWLINE: "\n"@4774..4775
      TEXT_LINE: "CuPy, PyTorch, JAX, or Dask arrays as array arguments. The following"@4775..4843
      NEWLINE: "\n"@4843..4844
      TEXT_LINE: "combinations of backend and device (or other capability) are supported."@4844..4915
      NEWLINE: "\n"@4915..4916
      BLANK_LINE: "\n"@4916..4917
      TEXT_LINE: "====================  ====================  ===================="@4917..4981
      NEWLINE: "\n"@4981..4982
      TEXT_LINE: "Library               CPU                   GPU"@4982..5029
      NEWLINE: "\n"@5029..5030
      TEXT_LINE: "====================  ====================  ===================="@5030..5094
      NEWLINE: "\n"@5094..5095
      TEXT_LINE: "NumPy                 ✅                     n/a"@5095..5144
      WHITESPACE: "                 "@5144..5161
      NEWLINE: "\n"@5161..5162
      TEXT_LINE: "CuPy                  n/a                   ⛔"@5162..5209
      WHITESPACE: "                   "@5209..5228
      NEWLINE: "\n"@5228..5229
      TEXT_LINE: "PyTorch               ✅                     ⛔"@5229..5278
      WHITESPACE: "                   "@5278..5297
      NEWLINE: "\n"@5297..5298
      TEXT_LINE: "JAX                   ⚠\u{fe0f} no JIT             ⛔"@5298..5349
      WHITESPACE: "                   "@5349..5368
      NEWLINE: "\n"@5368..5369
      TEXT_LINE: "Dask                  ⛔                     n/a"@5369..5418
      WHITESPACE: "                 "@5418..5435
      NEWLINE: "\n"@5435..5436
      TEXT_LINE: "====================  ====================  ===================="@5436..5500
      NEWLINE: "\n"@5500..5501
      BLANK_LINE: "\n"@5501..5502
      BLANK_LINE: "\n"@5502..5503
      BLANK_LINE: "\n"@5503..5504
      TEXT_LINE: "See :ref:`dev-arrayapi` for more information."@5504..5549
    }
  }
  NEWLINE: "\n"@5549..5550
  BLANK_LINE: "\n"@5550..5551
  BLANK_LINE: "\n"@5551..5552
  SECTION@5552..5779 {
    SECTION_HEADER@5552..5573 {
      NAME: "References"@5552..5562
      NEWLINE: "\n"@5562..5563
      UNDERLINE: "----------"@5563..5573
    }
    NEWLINE: "\n"@5573..5574
    CITATION@5574..5703 {
      DIRECTIVE_MARKER: ".."@5574..5576
      WHITESPACE: " "@5576..5577
      OPEN_BRACKET: "["@5577..5578
      LABEL: "1"@5578..5579
      CLOSE_BRACKET: "]"@5579..5580
      WHITESPACE: " "@5580..5581
      DESCRIPTION@5581..5703 {
        TEXT_LINE: "`Cubic Spline Interpolation"@5581..5608
        NEWLINE: "\n"@5608..5609
        WHITESPACE: "        "@5609..5617
        TEXT_LINE: "<https://en.wikiversity.org/wiki/Cubic_Spline_Interpolation>`_"@5617..5679
        NEWLINE: "\n"@5679..5680
        WHITESPACE: "        "@5680..5688
        TEXT_LINE: "on Wikiversity."@5688..5703
      }
    }
    NEWLINE: "\n"@5703..5704
    CITATION@5704..5779 {
      DIRECTIVE_MARKER: ".."@5704..5706
      WHITESPACE: " "@5706..5707
      OPEN_BRACKET: "["@5707..5708
