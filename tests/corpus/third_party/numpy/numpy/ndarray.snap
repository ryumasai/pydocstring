      WHITESPACE: " "@2642..2643
      COLON: ":"@2643..2644
      WHITESPACE: " "@2644..2645
      TYPE: "ndarray"@2645..2652
      NEWLINE: "\n"@2652..2653
      WHITESPACE: "    "@2653..2657
      DESCRIPTION@2657..2830 {
        TEXT_LINE: "If the array is a view into another array, that array is its `base`"@2657..2724
