    ENTRY@3067..3204 {
      NAME: "numpy.typing.NDArray"@3067..3087
      WHITESPACE: " "@3087..3088
      COLON: ":"@3088..3089
      WHITESPACE: " "@3089..3090
      DESCRIPTION@3090..3204 {
        TEXT_LINE: "An ndarray alias :term:`generic <generic type>`"@3090..3137
        NEWLINE: "\n"@3137..3138
        WHITESPACE: "                       "@3138..3161
        TEXT_LINE: "w.r.t. its `dtype.type <numpy.dtype.type>`."@3161..3204
