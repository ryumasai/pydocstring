    ENTRY@2153..2529 {
      NAME: "strides"@2153..2160
      WHITESPACE: " "@2160..2161
      COLON: ":"@2161..2162
      WHITESPACE: " "@2162..2163
      TYPE: "tuple of ints"@2163..2176
      NEWLINE: "\n"@2176..2177
      WHITESPACE: "    "@2177..2181
      DESCRIPTION@2181..2529 {
        TEXT_LINE: "The step-size required to move from one element to the next in"@2181..2243
        NEWLINE: "\n"@2243..2244
        WHITESPACE: "    "@2244..2248
        TEXT_LINE: "memory. For example, a contiguous ``(3, 4)`` array of type"@2248..2306
        NEWLINE: "\n"@2306..2307
        WHITESPACE: "    "@2307..2311
        TEXT_LINE: "``int16`` in C-order has strides ``(8, 2)``.  This implies that"@2311..2374
        NEWLINE: "\n"@2374..2375
        WHITESPACE: "    "@2375..2379
        TEXT_LINE: "to move from element to element in memory requires jumps of 2 bytes."@2379..2447
        NEWLINE: "\n"@2447..2448
        WHITESPACE: "    "@2448..2452
        TEXT_LINE: "To move from row-to-row, one needs to jump 8 bytes at a time"@2452..2512
        NEWLINE: "\n"@2512..2513
        WHITESPACE: "    "@2513..2517
        TEXT_LINE: "(``2 * 4``)."@2517..2529
      }
    }
