=== CST ===
DOCUMENT@0..40 {
  SUMMARY@0..8 {
    TEXT_LINE: "Summary."@0..8
  }
  NEWLINE: "\n"@8..9
  BLANK_LINE: "\n"@9..10
  SECTION@10..40 {
    SECTION_HEADER@10..15 {
      NAME: "Args"@10..14
      COLON: ":"@14..15
    }
    NEWLINE: "\n"@15..16
    WHITESPACE: "    "@16..20
    ENTRY@20..40 {
      NAME: "x"@20..21
      WHITESPACE: " "@21..22
      OPEN_BRACKET: "("@22..23
      TYPE: ""@23..23
      OPTIONAL: "optional"@23..31
      CLOSE_BRACKET: ")"@31..32
      COLON: ":"@32..33
      WHITESPACE: " "@33..34
      DESCRIPTION@34..40 {
        TEXT_LINE: "Value."@34..40
      }
    }
  }
}
